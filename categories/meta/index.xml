&lt;p>&lt;em>source: &lt;a href="https://tikzjax.com/">https://tikzjax.com/&lt;/a>&lt;/em>
&lt;div class="flex" width="full" height="full">
&lt;div class="flex-grow">&lt;/div>
&lt;script type="text/tikz">
\usepackage{tikz-cd}
\tikzcdset{scale cd/.style={every label/.append style={scale=#1},
cells={nodes={scale=#1}}}}
\begin{document}
\begin{tikzcd}[scale cd=2]
A \arrow[r, "\phi"] \arrow[d, red]
&amp; B \arrow[d, "\psi" red] \\
C \arrow[r, red, "\eta" blue]
&amp; |[blue, rotate=-15]| D
\end{tikzcd}
\end{document}
&lt;/script>
&lt;div class="flex-grow">&lt;/div>
&lt;/div>&lt;/p>
